# Override the WebSocket host used in useChat.ts.
# If not set, falls back to window.location.host (current browser host).
# Useful when the WS backend runs on a different host/port than the frontend.
# Example: VITE_WS_HOST=api.example.com:8000
VITE_WS_HOST=

# Set to "false" to hide the document-upload (+) button entirely.
# Any other value (or leaving it unset) keeps the feature enabled.
# In Docker, pass this as a build arg: --build-arg VITE_DOCUMENT_UPLOAD_ENABLED=false
VITE_DOCUMENT_UPLOAD_ENABLED=true
