# ============================================================================
# chatguru Agent - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# Usage: make env-setup (or manually: cp env.example .env)
#
# IMPORTANT: Never commit your .env file to version control!
# ============================================================================

# ============================================================================
# REQUIRED: LLM Configuration
# ============================================================================

# API key
# REQUIRED
LLM_API_KEY=your-api-key-here

# Model / deployment name
# REQUIRED: for OpenAI use the model name (gpt-4o-mini); for Azure use the deployment name
LLM_DEPLOYMENT_NAME=gpt-4o-mini

# Azure OpenAI API Version
# REQUIRED: API version to use
# Example: 2024-02-15-preview, 2023-12-01-preview
# Recommended: Use the latest preview version for new features
LLM_API_VERSION=2024-02-15-preview

# OpenAI v1-compatible chat base URL (optional)
# If set, chat uses POST {base}/chat/completions with the api-key header (e.g. Azure APIM).
# Leave empty to use native Azure OpenAI (OPENAI_ENDPOINT + LLM_API_VERSION + deployment).
# Full comparison: docs/design-decisions.md#llm-endpoint-modes
# Example: https://odin.devguru.co/openai/v1
# LLM_DEPLOYMENT_NAME must be the model id (e.g. gpt-5-mini).
LLM_OPENAI_BASE_URL=

# ============================================================================
# OPTIONAL: Embeddings Configuration
# ============================================================================

# Embeddings model / deployment name
# Default: text-embedding-ada-002
LLM_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002

# Embedding vector dimensions
# Default: 1536 (ada-002 / text-embedding-3-small)
LLM_EMBEDDING_DIMENSIONS=1536

# Embeddings endpoint override (optional)
# Set when the embeddings deployment is on a different endpoint than OPENAI_ENDPOINT.
# Defaults to OPENAI_ENDPOINT when empty.
# OPENAI_EMBEDDINGS_ENDPOINT=https://other-endpoint/openai/v1

# Embeddings API key override (optional)
# Defaults to LLM_API_KEY when empty.
# OPENAI_EMBEDDINGS_API_KEY=

# ============================================================================
# REQUIRED: Langfuse Configuration
# ============================================================================
# Langfuse provides observability, tracing, and monitoring for LLM applications.
# Sign up at https://langfuse.com/ to get your credentials.
# ============================================================================

# Langfuse Public Key
# REQUIRED: Your Langfuse public key (starts with pk-lf-)
# Example: pk-lf-abc123def456ghi789jkl012mno345pqr678stu901vwx234yz
# Get this from: Langfuse Dashboard > Settings > API Keys
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key

# Langfuse Secret Key
# REQUIRED: Your Langfuse secret key (starts with sk-lf-)
# Example: sk-lf-abc123def456ghi789jkl012mno345pqr678stu901vwx234yz
# Get this from: Langfuse Dashboard > Settings > API Keys
# Security: Keep this secret! Never commit to version control.
LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# Langfuse Host URL
# REQUIRED: Langfuse instance URL
# Default: https://cloud.langfuse.com (Langfuse Cloud)
# For self-hosted: https://your-langfuse-instance.com
LANGFUSE_HOST=https://cloud.langfuse.com

# Enable Langfuse Tracing
# Optional: Enable/disable Langfuse tracing
# Values: true, false
# Default: true
LANGFUSE_ENABLED=true

# ============================================================================
# OPTIONAL: FastAPI Configuration
# ============================================================================
# Configure the FastAPI server behavior.
# These have sensible defaults and usually don't need to be changed.
# ============================================================================

# FastAPI Host
# Optional: Host address to bind to
# Default: 0.0.0.0 (all interfaces)
# For local development only: 127.0.0.1
FASTAPI_HOST=0.0.0.0

# FastAPI Port
# Optional: Port number for the API server
# Default: 8000
# Change if port 8000 is already in use
FASTAPI_PORT=8000

# CORS Allowed Origins
# Optional: Allowed origins for CORS (JSON array format)
# Default: ["*"] (allow all origins)
# For production: ["https://yourdomain.com", "https://www.yourdomain.com"]
# Example: ["http://localhost:5173", "http://localhost:3000"]
FASTAPI_CORS_ORIGINS=["*"]

# ============================================================================
# OPTIONAL: Application Configuration
# ============================================================================
# General application settings.
# ============================================================================

# Application Name
# Optional: Name displayed in the UI and API responses
# Default: chatguru Agent
# Example: My Company Chatbot
APP_NAME=NG chatguru

# Debug Mode
# Optional: Enable debug mode (more verbose logging, stack traces)
# Values: true, false
# Default: false
# Warning: Set to false in production!
DEBUG=false

# Log Level
# Optional: Logging verbosity level
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# Recommended: INFO for production, DEBUG for development
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: Chat history persistence (SQLAlchemy async + Alembic)
# ============================================================================
# Leave unset (commented out) to DISABLE persistence — no messages are stored, no DB required.
# Set to any async SQLAlchemy URL to ENABLE it; then run `make migrate` once to create tables.
# Format: <dialect>+<async_driver>://... (must use an async-capable driver).
# Keep persistence/sqlalchemy/tables.py aligned with alembic migrations when editing schema.
#
# Local dev with SQLite vector service: use ONE file for chat + product vectors, e.g.:
#   PERSISTENCE_DATABASE_URL=sqlite+aiosqlite:///data/chatguru.db
#   VECTOR_SQLITE_DB_PATH=data/chatguru.db   (vector microservice process; path must match)
# Docker (sqlite profile): both services mount the same volume at /data — see docker-compose.yml.
# Examples:
#   sqlite+aiosqlite:///data/chatguru.db
#   sqlite+aiosqlite:////absolute/path/to/chatguru.db
#   postgresql+asyncpg://user:pass@localhost:5432/chatguru
#   mysql+aiomysql://user:pass@localhost:3306/chatguru
# ============================================================================

# PERSISTENCE_DATABASE_URL=sqlite+aiosqlite:///data/chatguru.db

# ============================================================================
# OPTIONAL: Conversation title generation provider
# ============================================================================
# Defaults to openai (uses the same LLM_* credentials as chat completions).
# Set to fallback for deterministic local-only title generation.
# Set to custom and provide TITLE_GENERATION_CUSTOM_CLASS to plug your own adapter.
# Values: openai, fallback, custom
# Default: openai
TITLE_GENERATION_PROVIDER=openai

# Required only when TITLE_GENERATION_PROVIDER=custom.
# Format: module.path:ClassName
# The class must implement async methods: connect(), generate(first_message), close().
# Example: TITLE_GENERATION_CUSTOM_CLASS=my_project.titlegen:MyTitleGenerator
# TITLE_GENERATION_CUSTOM_CLASS=

# ============================================================================
# OPTIONAL: Product Database Configuration
# ============================================================================
# Configure the product database backend.
# Supports two backends: SQLite (sqlite-vec) and MongoDB (Atlas Vector Search)
# ============================================================================

# Database Type
# Optional: Which database backend to use
# Values: sqlite, mongodb
# Default: mongodb (fully local, runs in Docker)
VECTOR_DB_TYPE=mongodb

# SQLite Database Service URL
# Optional: Full URL of the SQLite database service
# Default: http://localhost:8001
# Docker: http://vector-db:8001 (Docker Compose service name)
VECTOR_DB_SQLITE_URL=http://localhost:8001

# SQLite file for the vector microservice (products + embeddings). For a single local DB
# alongside PERSISTENCE_DATABASE_URL, point both at the same path (vector service uses this path).
# Default in code: /data/chatguru.db (Docker) or set e.g. data/chatguru.db for local runs.
# VECTOR_SQLITE_DB_PATH=data/chatguru.db

# ============================================================================
# MongoDB Configuration (Local Docker)
# ============================================================================
# Used when VECTOR_DB_TYPE=mongodb
# Default setup uses local MongoDB running in Docker (no external service needed)
# ============================================================================

# MongoDB Connection URI
# Default: Uses local MongoDB container with docker-compose
# For local Docker: mongodb://admin:password@localhost:27017
# For Atlas (cloud): mongodb+srv://username:password@cluster.mongodb.net
VECTOR_DB_MONGODB_URI=mongodb://admin:password@localhost:27017

# MongoDB Vector Database API Service URL
# Optional: Full URL of the MongoDB vector database API service (HTTP endpoint)
# Default: http://localhost:8002
# Docker: http://mongo-vector-db:8002 (Docker Compose service name)
# Note: This is the HTTP API wrapper, not the MongoDB connection URI
VECTOR_DB_MONGODB_API_URL=http://localhost:8002

# MongoDB Database Name
# Optional: Name of the MongoDB database to use
# Default: products
VECTOR_DB_MONGODB_DATABASE=products

# MongoDB Collection Name
# Optional: Name of the MongoDB collection to use
# Default: products
VECTOR_DB_MONGODB_COLLECTION=products

# Database Request Timeout
# Optional: Request timeout in seconds
# Default: 30
VECTOR_DB_TIMEOUT=30

# ============================================================================
# Quick Reference
# ============================================================================
# REQUIRED Variables:
#   - OPENAI_ENDPOINT  (OpenAI-compatible base URL, e.g. .../openai/v1)
#   - LLM_API_KEY
#   - LLM_DEPLOYMENT_NAME
#   - LANGFUSE_PUBLIC_KEY
#   - LANGFUSE_SECRET_KEY
#   - LANGFUSE_HOST
#
# OPTIONAL Variables (have defaults):
#   - OPENAI_EMBEDDINGS_ENDPOINT  (overrides OPENAI_ENDPOINT for embeddings only)
#   - OPENAI_EMBEDDINGS_API_KEY   (overrides LLM_API_KEY for embeddings only)
#   - LLM_EMBEDDING_DEPLOYMENT_NAME
#   - LLM_EMBEDDING_DIMENSIONS
#   - VECTOR_DB_* (database configuration)
#   - All others can be left as-is for basic usage
#
# Security Notes:
#   - Never commit .env to version control
#   - Keep API keys secret
#   - Use environment-specific values for production
#
# Docker Compose:
#   - Set VECTOR_DB_SQLITE_URL=http://chatguru-sqlite-db:8001 when using docker-compose
#   - The SQLite database service runs on port 8001 by default
# ============================================================================
