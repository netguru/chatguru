# ============================================================================
# chatguru — MongoDB Vector Database Service
# ============================================================================
# This image is intentionally lean: only the [dependency-groups] vector-db
# packages are installed (fastapi, pymongo, langchain-openai, …).
# The main project dependencies (docling, torch, etc.) are skipped entirely
# via `uv sync --only-group vector-db`.
# ============================================================================

FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /bin/uv

WORKDIR /app
COPY pyproject.toml uv.lock ./

RUN uv sync --frozen --only-group vector-db

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app/src \
    VECTOR_STORE_TYPE=mongodb \
    PATH="/app/.venv/bin:$PATH"

WORKDIR /app

COPY --from=builder /app/.venv ./.venv

# Copy only the files this service needs
COPY src/vector_db/api.py ./src/vector_db/api.py
COPY src/vector_db/mongodb_store.py ./src/vector_db/mongodb_store.py
COPY src/config.py ./src/config.py
COPY src/rag/products.json ./data/products.json

RUN touch ./src/vector_db/__init__.py

EXPOSE 8002

CMD ["uvicorn", "vector_db.api:app", "--host", "0.0.0.0", "--port", "8002"]
